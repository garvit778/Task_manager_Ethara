{
  "info": {
    "name": "ProjectPilot API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" },
    { "key": "projectId", "value": "" },
    { "key": "taskId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@projectpilot.dev\",\n  \"password\": \"Password123!\"\n}" },
        "url": "{{baseUrl}}/auth/login"
      }
    },
    {
      "name": "Auth - Me",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/auth/me"
      }
    },
    {
      "name": "Dashboard",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/dashboard"
      }
    },
    {
      "name": "Projects - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"title\": \"Mobile App Redesign\",\n  \"description\": \"Ship a refined project experience for mobile users.\",\n  \"priority\": \"HIGH\"\n}" },
        "url": "{{baseUrl}}/projects"
      }
    },
    {
      "name": "Projects - List",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/projects"
      }
    },
    {
      "name": "Tasks - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"title\": \"Create kanban polish pass\",\n  \"projectId\": \"{{projectId}}\",\n  \"priority\": \"MEDIUM\",\n  \"status\": \"TODO\"\n}" },
        "url": "{{baseUrl}}/tasks"
      }
    },
    {
      "name": "Tasks - Move",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"status\": \"IN_PROGRESS\"\n}" },
        "url": "{{baseUrl}}/tasks/{{taskId}}"
      }
    },
    {
      "name": "Tasks - Comment",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"body\": \"Looks ready for QA.\"\n}" },
        "url": "{{baseUrl}}/tasks/{{taskId}}/comments"
      }
    }
  ]
}
